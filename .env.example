# Copy this file to .env and fill in your own values.
# .env is gitignored. NEVER put a real key or project id in this file — it is
# committed, and that is exactly how the last key got leaked and auto-revoked.

# --- Vertex AI (the default backend) ---
# Gemini billed to your Google Cloud project, so Cloud credits apply.
# There is no API key: authenticate with Application Default Credentials.
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <your-project-id>
GOOGLE_CLOUD_PROJECT=

# --- Google AI Studio (only if you set gemini.backend to "aistudio") ---
# Unused on Vertex. Note this needs prepaid credits ON THE KEY —
# Google Cloud credits do NOT apply to AI Studio.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Hugging Face (for downloading the Whisper model) ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1
# Optional token, avoids rate limits on model downloads
# HF_TOKEN=
